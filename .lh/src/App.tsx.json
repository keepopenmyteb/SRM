d\" strokeLinejoin=\"round\" />\n              </svg>\n            </button>\n          </div>\n        </div>\n      </header>\n\n      <div className=\"layout\">\n        <aside className=\"sidebar\">\n          <div className=\"profile\">\n            <div className=\"avatar\" aria-hidden=\"true\">\n              <svg viewBox=\"0 0 48 48\">\n                <circle cx=\"24\" cy=\"18\" r=\"9\" />\n                <path d=\"M10 40c2.5-7 9-11 14-11s11.5 4 14 11\" />\n              </svg>\n            </div>\n            <div className=\"profile-meta\">\n              <div className=\"profile-name\">관리자</div>\n              <div className=\"profile-email\">admin@gmail.com</div>\n            </div>\n          </div>\n\n          <div className=\"menu-label\">메뉴</div>\n          <nav className=\"menu\">\n            <button className=\"menu-item active\" type=\"button\">\n              <span className=\"menu-icon\" aria-hidden=\"true\">\n                <img\n                  className=\"menu-icon-img\"\n                  src=\"/dashboard-icon.svg\"\n                  alt=\"\"\n                />\n              </span>\n              <span>대시보드</span>\n            </button>\n            <button className=\"menu-item\" type=\"button\">\n              <span className=\"menu-icon\" aria-hidden=\"true\">\n                <img\n                  className=\"menu-icon-img\"\n                  src=\"/ image-list-icon\"\n                  alt=\"\"\n                />\n              </span>\n              <span>이미지 목록</span>\n            </button>\n            <button className=\"menu-item\" type=\"button\">\n              <span className=\"menu-icon\" aria-hidden=\"true\">\n                <img\n                  className=\"menu-icon-img\"\n                  src=\"/remote-migration-icon.svg\"\n                  alt=\"\"\n                />\n              </span>\n              <span>원격 마이그레이션</span>\n            </button>\n          </nav>\n        </aside>\n\n        <main 